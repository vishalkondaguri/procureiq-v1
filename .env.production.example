# ──────────────────────────────────────────────────────────────────────────────
# ProcureIQ v1.0 — PRODUCTION Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.production and fill in every value marked REQUIRED.
# NEVER commit .env.production to source control.
#
# Use with:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# REQUIRED — your public-facing HTTPS URL (no trailing slash)
FRONTEND_URL=https://procureiq.yourcompany.com

# REQUIRED — must match FRONTEND_URL so CORS works correctly
# For multiple domains: ["https://procureiq.yourcompany.com","https://admin.yourcompany.com"]
ALLOWED_ORIGINS=["https://procureiq.yourcompany.com"]

# Disable Swagger UI / ReDoc in production (recommended)
SHOW_API_DOCS=false

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED — strong password, never use defaults
POSTGRES_USER=procureiq
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=procureiq
# DATABASE_URL is constructed automatically from the above in docker-compose.prod.yml

# ── Redis ─────────────────────────────────────────────────────────────────────
# REQUIRED — protects Redis from unauthenticated access
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# ── Storage ───────────────────────────────────────────────────────────────────
# Choose ONE provider:
#
# Option A: Local disk (simplest — files in Docker volume, no external dependency)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/app/uploads
STORAGE_BUCKET=procureiq-documents
#
# Option B: IBM Cloud Object Storage
# STORAGE_PROVIDER=ibm_cos
# STORAGE_BUCKET=procureiq-documents
# STORAGE_ENDPOINT_URL=https://s3.us-south.cloud-object-storage.appdomain.cloud
# STORAGE_ACCESS_KEY=your-ibm-cos-hmac-access-key-id
# STORAGE_SECRET_KEY=your-ibm-cos-hmac-secret-access-key
# STORAGE_REGION=us-south
#
# Option C: AWS S3
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=procureiq-documents
# STORAGE_ENDPOINT_URL=
# STORAGE_ACCESS_KEY=your-aws-access-key-id
# STORAGE_SECRET_KEY=your-aws-secret-access-key
# STORAGE_REGION=us-east-1
#
# Option D: MinIO (self-hosted S3-compatible, good for on-prem / air-gapped)
# STORAGE_PROVIDER=s3
# STORAGE_BUCKET=procureiq-documents
# STORAGE_ENDPOINT_URL=https://minio.yourcompany.com
# STORAGE_ACCESS_KEY=your-minio-access-key
# STORAGE_SECRET_KEY=your-minio-secret-key
# STORAGE_REGION=us-east-1
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-south
STORAGE_PRESIGN_EXPIRY=3600

# ── IBM watsonx ───────────────────────────────────────────────────────────────
# Required for Ignite AI features — get from IBM Cloud console
WATSONX_API_KEY=your_ibm_cloud_api_key
WATSONX_PROJECT_ID=your_watsonx_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_ENABLED=true
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@yourcompany.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=ProcureIQ <noreply@yourcompany.com>
RESET_TOKEN_EXPIRE_MINUTES=60

# ── Base currency ─────────────────────────────────────────────────────────────
BASE_CURRENCY=USD
