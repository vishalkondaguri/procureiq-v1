# ProcureIQ v1.0 — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
#
# For production deployment, see .env.production.example instead.

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=replace-with-a-64-char-random-secret

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://procureiq:procureiq@localhost:5432/procureiq

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Storage ───────────────────────────────────────────────────────────────────
# STORAGE_PROVIDER selects the backend:
#   local     — files written to STORAGE_LOCAL_PATH on disk (default for dev)
#   s3        — AWS S3 or any S3-compatible store (MinIO, Wasabi, etc.)
#   ibm_cos   — IBM Cloud Object Storage
#
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/tmp/procureiq-uploads
STORAGE_BUCKET=procureiq-documents

# For s3 / ibm_cos providers — fill these in:
# STORAGE_ENDPOINT_URL=http://localhost:9000   # MinIO dev endpoint
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_REGION=us-south
# STORAGE_PRESIGN_EXPIRY=3600

# Legacy MinIO vars (still work if STORAGE_PROVIDER is not set)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=procureiq-documents

# ── IBM watsonx ───────────────────────────────────────────────────────────────
WATSONX_API_KEY=your_ibm_cloud_api_key
WATSONX_PROJECT_ID=your_watsonx_project_id
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# ── Ollama (optional local AI fallback) ───────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_ENABLED=false

# ── Base currency ─────────────────────────────────────────────────────────────
BASE_CURRENCY=USD

# ═════════════════════════════════════════════════════════════════════════════
# EMAIL / SMTP CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════
#
# Set SMTP_ENABLED=true and fill in your SMTP credentials to enable:
#   - Welcome emails with temp passwords when approving new users
#   - Password-reset emails when users click "Forgot Password"
#
# ── Option A: Gmail (recommended for demo/testing) ───────────────────────────
#
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification (required for App Passwords)
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Create an App Password → select "Mail" + "Windows Computer"
#   5. Copy the 16-character app password (e.g. "abcd efgh ijkl mnop")
#   6. Paste it as SMTP_PASSWORD below (spaces are fine, or remove them)
#
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=ProcureIQ <your-gmail@gmail.com>

# ── Option B: Microsoft Outlook / Office 365 ─────────────────────────────────
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your-email@company.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=ProcureIQ <your-email@company.com>

# ── Option C: Any SMTP provider (port 465 / SSL) ─────────────────────────────
# SMTP_HOST=mail.yourprovider.com
# SMTP_PORT=465
# SMTP_USER=your-email@company.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=ProcureIQ <noreply@company.com>

# ── Option D: Mailtrap (safe email testing — no real emails sent) ─────────────
# https://mailtrap.io — sign up free, get SMTP credentials
# SMTP_HOST=live.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=api
# SMTP_PASSWORD=your-mailtrap-token
# SMTP_FROM=ProcureIQ <hello@procureiq.ai>

# ── Frontend URL (used in reset-password email links) ────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Password reset token expiry (minutes) ────────────────────────────────────
RESET_TOKEN_EXPIRE_MINUTES=60
